{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyCodeBuddy",
  "mainBinaryName": "MyCodeBuddy",
  "version": "0.20.0-mycodebuddy.1",
  "identifier": "app.mycodebuddy",
  "build": {
    "beforeDevCommand": "pnpm tauri:before-dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm tauri:before-build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "publisher": "MyCodeBuddy contributors",
    "homepage": "https://github.com/icannotwait/MyCodeBuddy",
    "license": "Apache-2.0",
    "licenseFile": "../LICENSE",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../out": "web/",
      "../LICENSE": "licenses/LICENSE",
      "../NOTICE": "licenses/NOTICE",
      "resources/THIRD_PARTY_LICENSES.txt": "licenses/THIRD_PARTY_LICENSES.txt"
    },
    "externalBin": ["binaries/codeg-mcp"],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDA4QUIwRUY2OUVCRTczM0EKUldRNmM3NmU5ZzZyQ0NmdlEzNmc2czl1UnRVSnpQTGMzRW1SbXFtdWx4dVVyYU5DMGVPYzkxYk8K",
      "endpoints": [
        "https://github.com/icannotwait/MyCodeBuddy/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
